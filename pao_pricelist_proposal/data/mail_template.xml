<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="mail_template_pricelist_proposal" model="mail.template">
            <field name="name">Pricelist Proposal Template</field>
            <field name="model_id" ref="pao_pricelist_proposal.model_send_pricelist_proposal"/>
            <field name="subject">Propuesta de precios preferenciales</field>
            <field name="body_html" type="html">
                <p style="font-size:12pt; font-family:Tahoma,sans-serif; color:#000000; line-height:1.0;">
                    <b>Estimado {customer_name}</b>
                    <br/><br/>
                    Reiterando nuestro agradecimiento por su confianza al considerarnos su proveedor de servicios en auditorías de tercera
                    parte en inocuidad agroalimentaria, le hacemos llegar la propuesta de precios preferenciales para sus auditorías durante
                    la temporada 2023-2024.
                    <br/><br/>
                    Puede visualizar la propuesta de precios preferenciales haciendo click <a href="{proposal_link}" target="_blank">aquí.</a>
                    <br/><br/>
                    Sin otro particular quedamos para cualquier duda o comentario.
                    <br/><br/>
                    Atentamente
                    <br/><br/>
                    {specialist}
                </p>         
            </field>
            <!-- <field name="body_html_english" type="html">
                <p style="font-size:12pt; font-family:Tahoma,sans-serif; color:#000000; line-height:1.0;">
                    <b>Dear {customer_name}</b>
