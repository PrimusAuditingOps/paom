<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="pao_cr_visits_report_view_form" model="ir.ui.view">
        <field name="name">pao.cr.visits.report.view.form</field>
        <field name="model">pao.cr.visits.report</field>
        <field name="arch" type="xml">
            <form string="CR visits report Form">
                <sheet>
                    <group col="4">
                        <field name="audit_scheme"/>
                        <field name="coordinator_name"/>    
                        <field name="audit_id"/>
                        <field name="month"/>
                        <field name="audit_date"/>
                        <field name="year"/>
                        <field name="cb"/>
                        <field name="registration_number"/>
                        <field name="organization_name"/>
                        <field name="commodities"/>
                        <field name="contact_name"/>
                        <field name="email"/>
                        <field name="country"/>
                        <field name="state"/>
                        <field name="city"/>
                        <field name="locations"/>
                        <field name="operation_type"/>
                        <field name="shipper"/>
                        <field name="value"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="pao_cr_visits_report_view_tree" model="ir.ui.view">
        <field name="name">pao.cr.visits.report.view.tree</field>
        <field name="model">pao.cr.visits.report</field>
        <field name="arch" type="xml">
            <tree string="CR Visits Report Tree">
                <field name="audit_scheme"/>
                <field name="coordinator_name"/>    
                <field name="audit_id"/>
                <field name="month"/>
                <field name="audit_date"/>
                <field name="year"/>
                <field name="cb"/>
                <field name="registration_number"/>
                <field name="organization_name"/>
                <field name="commodities"/>
                <field name="contact_name"/>
                <field name="email"/>
                <field name="country"/>
                <field name="state"/>
                <field name="city"/>
                <field name="locations"/>
                <field name="operation_type"/>
                <field name="shipper"/>
                <field name="value"/>
            </tree>
        </field>
    </record>


    <record id="pao_cr_visits_report_action" model="ir.actions.act_window">
        <field name="name">CR Visits Report</field>
        <field name="res_model">pao.cr.visits.report</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create first CR visits report
            </p>
        </field>
    </record>

    <menuitem id="pao_cr_visits_report"
            name="CR Visits Report"
            parent="sale.sale_order_menu"
            action="pao_cr_visits_report_action"
            sequence="15"/>

</odoo>