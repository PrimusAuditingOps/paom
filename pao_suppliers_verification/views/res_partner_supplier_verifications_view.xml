<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_partner_suppliers_verification_form" model="ir.ui.view">
        <field name="name">res.partner.suppliers.verification.form</field>
        <field name="model">res.partner</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='category_id']" position="after">
                <field name="supplier_rank" invisible="1"/>
                <field name="affects_certification_process" attrs="{'invisible': [('supplier_rank', '&lt;=', 0)]}"/>
                <field name="service_type_id" options="{'no_create': True}" attrs="{'invisible': [('supplier_rank', '&lt;=', 0)]}"/>
                <field name="branch_office_ids" widget="many2many_tags" options="{'no_create': True}" attrs="{'invisible': [('supplier_rank', '&lt;=', 0)]}"/>
            </xpath>

            <!-- <xpath expr="//field[@name='category_id']" position="after">
                <field name="affects_certification_process" invisible="supplier_rank &lt;= 0)]}"/>
                <field name="service_type_id" invisible="supplier_rank &lt;= 0)]}"/>
                <field name="branch_office_ids" invisible="supplier_rank &lt;= 0)]}"/>
            </xpath> -->
            
        </field>
    </record>

    <record id="res_partner_suppliers_verification_search" model="ir.ui.view">
        <field name="name">res.partner.suppliers.verification.search</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search>
                <filter name="filter_affects_certification_process" string="Affects the certification process" domain="[('affects_certification_process', '=', True)]"/>

                <filter name="group_service_id" string="Service Type" context="{'group_by':'service_type_id'}"/>
                <filter name="group_branch_id" string="Brnach Office" context="{'group_by':'branch_office_ids'}"/>
            </search>
        </field>
    </record>
</odoo>